# ---------------------------------------------------------------------------
# Deployment configuration. Copy to deploy/config.env and edit.
#   cp deploy/config.env.example deploy/config.env
#
# You provide the VM yourself (any cloud / bare metal). These scripts only need
# SSH access — no gcloud, no provider CLI.
# ---------------------------------------------------------------------------

# --- Target VM (reached over plain SSH) ------------------------------------
SSH_HOST="203.0.113.10"              # VM public IP or hostname
SSH_USER="deploy"                    # SSH login (needs sudo to run docker)
SSH_PORT="22"
SSH_KEY="$HOME/.ssh/id_ed25519"      # private key path (omit to use ssh-agent/default)

# Where the app lives on the VM.
REMOTE_DIR="/opt/fluffy-enigma"

# Optional public hostname for the app + automatic HTTPS. When set it is used
# for APP_URL and Caddy TLS. Leave empty to serve plain HTTP on SSH_HOST.
DOMAIN=""

# Swap file created during one-time configuration (recommended on 1 GB RAM).
SWAP_SIZE="2G"

# --- Container registry (GitHub Container Registry) ------------------------
# Image is built + pushed from your machine and PULLED on the VM (no build on
# the VM). Full repo = IMAGE_REGISTRY/IMAGE_OWNER/IMAGE_NAME.
IMAGE_REGISTRY="ghcr.io"
IMAGE_OWNER="your-github-username"   # lowercase GitHub user or org
IMAGE_NAME="fluffy-enigma"

# Auth: GitHub Personal Access Token (classic) with write:packages (push) and
# read:packages (pull). Export before pushing/deploying:
#   export GHCR_TOKEN=ghp_xxxxxxxx
# Private package? The VM also needs read access — export the same (or a
# read-only) token before deploying:
#   export GHCR_PULL_TOKEN=$GHCR_TOKEN
# Or make the GHCR package public to skip VM login entirely.
