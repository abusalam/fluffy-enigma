# Normalise line endings: store as LF in the repo and check out as LF on all
# platforms. Critical for the shell scripts / entrypoints that run on Linux —
# a stray CRLF would break them with `bash: $'\r': command not found`.
* text=auto eol=lf

# Scripts and config that MUST be LF.
*.sh        text eol=lf
*.php       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
Dockerfile  text eol=lf
Caddyfile   text eol=lf
*.json      text eol=lf
*.blade.php text eol=lf

# Binary assets — never touch.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff binary
*.woff2 binary
